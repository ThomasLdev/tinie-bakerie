{% extends 'base.html.twig' %}

{% block title %}{{ category.title }}{% endblock %}

{% block header %}
    {% include 'category/seo/_meta.html.twig' %}
{% endblock %}

{% block body %}
    <div class="bg-white border-b">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="text-center">
                <h1 class="text-4xl font-playfair font-bold text-gray-900 mb-4">{{ category.title }}</h1>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">{{ category.description }}</p>
            </div>
            {% for medium in category.media %}
                <twig:Cover :attachment="medium" variation="medium" autoplay />
            {% endfor %}
        </div>
    </div>

    {% set posts = category.posts %}

    {% if posts is not same as null and posts is not empty %}
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for post in posts %}
                {% set mainMedia = post.media|first %}

                <a class="bg-white shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden group cursor-pointer"
                   href="{{ path('app_recipe_show', {'recipeSlug': post.slug, 'categorySlug': category.slug}) }}"
                >
                    <div class="aspect-square overflow-hidden">
                        <twig:Cover :attachment="mainMedia" variation="thumbnail" autoplay />
                    </div>
                    <div class="p-4">
                        <div class="flex items-center gap-2 mb-2">
                            {% for tag in post.tags %}
                                <span class="inline-block px-2 py-1 text-xs rounded-full">
                                {{ tag.title }}
                            </span>
                            {% endfor %}
                        </div>
                        <h3 class="font-semibold text-gray-900 mb-2 group-hover:text-gray-700">{{ post.title }}</h3>
                        <p class="text-sm text-gray-600 mb-3 line-clamp-2">{{ post.excerpt }}</p>
                        <div class="flex items-center justify-between text-xs text-gray-500">
                            <div class="flex items-center space-x-4">
                                <span>⏱️ 25 min</span>
                                <span>👨‍🍳 Easy</span>
                            </div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock body %}
