{% set notebookLinks = [
    { label: 'footer.notebook.techniques'|trans({}, 'layout'),  href: '#' },
    { label: 'footer.notebook.seasonal'|trans({}, 'layout'),    href: '#' },
    { label: 'footer.notebook.ingredients'|trans({}, 'layout'), href: '#' },
    { label: 'footer.notebook.interviews'|trans({}, 'layout'),  href: '#' },
] %}

{% set socials = [
    { label: 'footer.socials.instagram'|trans({}, 'layout'), href: '#' },
    { label: 'footer.socials.pinterest'|trans({}, 'layout'), href: '#' },
    { label: 'footer.socials.youtube'|trans({}, 'layout'),   href: '#' },
] %}

<footer {{ attributes.defaults({class: 'footer'}) }}>
    <div class="wrap">
        <div class="footer__top">
            <div class="footer__grid">
                <div class="footer__brand">
                    <a href="{{ path('app_homepage_index') }}" class="logo footer__logo">
                        <span class="logo__mark" aria-hidden="true">t</span>
                        <span class="logo__text">TINIE <span class="logo__brand">BAKERIE</span></span>
                    </a>
                    <p class="footer__tagline">{{ 'footer.tagline'|trans({}, 'layout') }}</p>
                </div>

                <details class="footer__col" open>
                    <summary class="footer__head">
                        <span>{{ 'footer.recipes.title'|trans({}, 'layout') }}</span>
                        <span class="footer__chev" aria-hidden="true">
                            <twig:ux:icon name="lucide:plus" width="18" height="18" />
                        </span>
                    </summary>
                    <div class="footer__body">
                        <ul class="footer__links" aria-label="{{ 'footer.recipes.title'|trans({}, 'layout') }}">
                            {% for category in this.featuredCategories %}
                                <li class="footer__links-item">
                                    <a href="{{ path('app_category_show', {categorySlug: category.slug}) }}"
                                       class="footer__link">{{ category.title }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </details>

                <details class="footer__col">
                    <summary class="footer__head">
                        <span>{{ 'footer.notebook.title'|trans({}, 'layout') }}</span>
                        <span class="footer__chev" aria-hidden="true">
                            <twig:ux:icon name="lucide:plus" width="18" height="18" />
                        </span>
                    </summary>
                    <div class="footer__body">
                        <ul class="footer__links" aria-label="{{ 'footer.notebook.title'|trans({}, 'layout') }}">
                            {% for link in notebookLinks %}
                                <li class="footer__links-item">
                                    <a href="{{ link.href }}" class="footer__link">{{ link.label }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </details>

                <details class="footer__col footer__col--newsletter">
                    <summary class="footer__head">
                        <span>{{ 'footer.newsletter.title'|trans({}, 'layout') }}</span>
                        <span class="footer__chev" aria-hidden="true">
                            <twig:ux:icon name="lucide:plus" width="18" height="18" />
                        </span>
                    </summary>
                    <div class="footer__body">
                        <p class="footer__note">{{ 'footer.newsletter.note'|trans({}, 'layout') }}</p>
                        <form class="footer__form" method="post" action="#">
                            <label for="footer-newsletter-email" class="sr-only">
                                {{ 'footer.newsletter.email_label'|trans({}, 'layout') }}
                            </label>
                            <input
                                id="footer-newsletter-email"
                                class="footer__input"
                                type="email"
                                name="email"
                                required
                                autocomplete="email"
                                placeholder="{{ 'footer.newsletter.email_placeholder'|trans({}, 'layout') }}"
                            />
                            <twig:Button variant="primary" size="sm" class="footer__submit">
                                {{ 'footer.newsletter.submit'|trans({}, 'layout') }}
                            </twig:Button>
                        </form>
                    </div>
                </details>
            </div>
        </div>

        <div class="footer__bottom">
            <span class="footer__copy">
                &copy; {{ "now"|date("Y") }} Tinie Bakerie · {{ 'footer.copyright'|trans({}, 'layout') }}
            </span>
            <ul class="footer__socials" aria-label="{{ 'footer.socials.aria_label'|trans({}, 'layout') }}">
                {% for social in socials %}
                    <li class="footer__socials-item">
                        <a href="{{ social.href }}" class="footer__social" rel="noopener">{{ social.label }}</a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</footer>
