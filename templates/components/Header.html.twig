{% set currentRoute = app.request.attributes.get('_route') %}
{% set items = [
    { label: 'header.nav.home'|trans({}, 'layout'),    icon: 'lucide:house',  href: path('app_homepage_index'), route: 'app_homepage_index' },
    { label: 'header.nav.recipes'|trans({}, 'layout'), icon: 'lucide:cookie', href: path('app_recipe_index'),   route: 'app_recipe_index' },
] %}

<div class="nav-wrapper">
    <nav {{ attributes.defaults({class: 'nav'}) }} aria-label="{{ 'header.nav.aria_label'|trans({}, 'layout') }}">
        <div class="nav__inner">
            <a href="{{ path('app_homepage_index') }}" class="logo">
                <span class="logo__mark" aria-hidden="true">t</span>
                <span class="logo__text">TINIE <span class="logo__brand">BAKERIE</span></span>
            </a>

            <ul class="nav__links">
                {% for item in items %}
                    {% set isCurrent = item.route == currentRoute %}
                    <li>
                        <a href="{{ item.href }}"
                           class="nav__link{% if isCurrent %} nav__link--active{% endif %}"
                           {% if isCurrent %}aria-current="page"{% endif %}>
                            {{ item.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            <ul class="nav__icons">
                {% for item in items %}
                    {% set isCurrent = item.route == currentRoute %}
                    <li>
                        <a href="{{ item.href }}"
                           class="nav__icon"
                           {% if isCurrent %}aria-current="page"{% endif %}>
                            <twig:ux:icon name="{{ item.icon }}" width="18" height="18" aria-hidden="true" />
                            <span class="nav__icon-label">{{ item.label }}</span>
                        </a>
                    </li>
                {% endfor %}
                <li>
                    <button type="button"
                            class="nav__icon"
                            data-search-open
                            aria-controls="search-panel">
                        <twig:ux:icon name="lucide:search" width="18" height="18" aria-hidden="true" />
                        <span class="nav__icon-label">{{ 'header.search'|trans({}, 'layout') }}</span>
                    </button>
                </li>
            </ul>

            <div class="nav__right">
                <twig:IconButton label="{{ 'header.search'|trans({}, 'layout') }}"
                                 data-search-open
                                 aria-controls="search-panel">
                    <twig:ux:icon name="lucide:search" width="20" height="20" aria-hidden="true" />
                </twig:IconButton>
            </div>
        </div>
    </nav>
</div>
