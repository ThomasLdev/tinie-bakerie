{% set currentRoute = app.request.attributes.get('_route') %}
{% set items = [
    { label: 'header.nav.home'|trans({}, 'layout'),     href: path('app_homepage_index'), route: 'app_homepage_index' },
    { label: 'header.nav.recipes'|trans({}, 'layout'),  href: path('app_post_index'),     route: 'app_post_index' },
    { label: 'header.nav.notebook'|trans({}, 'layout'), href: '#',                        route: null },
    { label: 'header.nav.about'|trans({}, 'layout'),    href: '#',                        route: null },
] %}

<div data-controller="drawer">
    <nav {{ attributes.defaults({class: 'nav'}) }} aria-label="{{ 'header.nav.aria_label'|trans({}, 'layout') }}">
        <div class="nav__inner">
            <a href="{{ path('app_homepage_index') }}" class="logo">
                <span class="logo__mark" aria-hidden="true">t</span>
                <span class="logo__text">TINIE <span class="logo__brand">BAKERIE</span></span>
            </a>

            <ul class="nav__links">
                {% for item in items %}
                    <li>
                        <a href="{{ item.href }}"
                           class="nav__link{% if item.route and item.route == currentRoute %} nav__link--active{% endif %}"
                           {% if item.route and item.route == currentRoute %}aria-current="page"{% endif %}>
                            {{ item.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            <div class="nav__right">
                <twig:IconButton label="{{ 'header.search'|trans({}, 'layout') }}"
                                 data-search-open
                                 aria-controls="search-panel">
                    <twig:ux:icon name="lucide:search" width="18" height="18" aria-hidden="true" />
                </twig:IconButton>
                <twig:Button variant="ghost" size="sm" href="#" class="nav__newsletter">{{ 'header.newsletter'|trans({}, 'layout') }}</twig:Button>
                <twig:IconButton label="{{ 'header.menu.open'|trans({}, 'layout') }}"
                                 class="nav__menu-btn"
                                 data-drawer-target="trigger"
                                 data-action="drawer#open"
                                 aria-expanded="false"
                                 aria-controls="drawer-panel">
                    <twig:ux:icon name="lucide:menu" width="20" height="20" aria-hidden="true" />
                </twig:IconButton>
            </div>
        </div>
    </nav>

    <div class="drawer__backdrop"
         data-drawer-target="backdrop"
         data-action="drawer#close"
         aria-hidden="true"></div>

    <div class="drawer"
         id="drawer-panel"
         role="dialog"
         aria-modal="true"
         aria-label="{{ 'header.menu.aria_label'|trans({}, 'layout') }}"
         data-drawer-target="panel"
         inert>
        <div class="drawer__head">
            <a href="{{ path('app_homepage_index') }}" class="logo" tabindex="-1" aria-hidden="true">
                <span class="logo__mark">t</span>
                <span class="logo__text">TINIE <span class="logo__brand">BAKERIE</span></span>
            </a>
            <twig:IconButton label="{{ 'header.menu.close'|trans({}, 'layout') }}"
                             data-drawer-target="initialFocus"
                             data-action="drawer#close">
                <twig:ux:icon name="lucide:x" width="20" height="20" aria-hidden="true" />
            </twig:IconButton>
        </div>

        <nav aria-label="{{ 'header.menu.mobile_aria_label'|trans({}, 'layout') }}">
            <ul class="drawer__links">
                {% for item in items %}
                    <li>
                        <a href="{{ item.href }}"
                           class="drawer__link{% if item.route and item.route == currentRoute %} drawer__link--active{% endif %}"
                           {% if item.route and item.route == currentRoute %}aria-current="page"{% endif %}
                           data-action="drawer#close">
                            {{ item.label }}
                            <span class="drawer__arr" aria-hidden="true">→</span>
                        </a>
                    </li>
                {% endfor %}
                <li>
                    <a href="#" class="drawer__link" data-action="drawer#close">
                        {{ 'header.newsletter'|trans({}, 'layout') }}
                        <span class="drawer__arr" aria-hidden="true">→</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="drawer__foot">
            <span class="drawer__small">{{ 'header.follow'|trans({}, 'layout') }}</span>
            <ul class="drawer__socials">
                <li><a href="#" class="drawer__social">Instagram</a></li>
                <li><a href="#" class="drawer__social">Pinterest</a></li>
                <li><a href="#" class="drawer__social">YouTube</a></li>
            </ul>
        </div>
    </div>
</div>
