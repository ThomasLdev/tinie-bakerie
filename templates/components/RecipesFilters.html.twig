{# @var props {
    chips: list<{label: string, slug: string|null, active: bool}>,
    sortOptions: list<{value: string, label: string}>,
    activeSort: string,
} #}
{% props
    chips = [],
    sortOptions = [],
    activeSort = '',
%}

<aside {{ attributes.defaults({
    class: 'recipes-filters',
    'aria-label': 'recipes.filters.aria_label'|trans,
}) }}>
    <div class="wrap recipes-filters__row">
        <div class="recipes-filters__chips" role="tablist" aria-label="{{ 'recipes.filters.categories_aria'|trans }}">
            {% for chip in chips %}
                <button
                    type="button"
                    role="tab"
                    class="recipes-filters__chip{% if chip.active %} recipes-filters__chip--active{% endif %}"
                    aria-selected="{{ chip.active ? 'true' : 'false' }}"
                >
                    {{ chip.label }}
                </button>
            {% endfor %}
        </div>

        {% if sortOptions|length > 0 %}
            <label class="recipes-filters__sort">
                <twig:ux:icon name="lucide:arrow-down-up" class="recipes-filters__sort-icon" aria-hidden="true" />
                <span class="sr-only">{{ 'recipes.filters.sort_label'|trans }}</span>
                <select class="recipes-filters__sort-select">
                    {% for option in sortOptions %}
                        <option value="{{ option.value }}"{% if option.value == activeSort %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </label>
        {% endif %}
    </div>
</aside>
