<div data-controller="search live"
     {{ attributes.defaults({
         class: 'search',
         role: 'dialog',
         'aria-modal': 'true',
         'aria-label': 'search.aria_label'|trans({}, 'layout'),
     }).without('data-controller') }}
     data-search-target="panel">
    <header class="search__head">
        <label class="search__input-wrap">
            <twig:ux:icon name="lucide:search" class="search__icon" aria-hidden="true" />
            <span class="sr-only">{{ 'search.label'|trans({}, 'layout') }}</span>
            <input type="search"
                   class="search__input"
                   data-search-target="input"
                   data-model="debounce(300)|query"
                   value="{{ query }}"
                   placeholder="{{ 'search.placeholder'|trans({}, 'messages') }}"
                   autocomplete="off"
                   enterkeyhint="search">
            {% if query is not empty %}
                <button type="button"
                        class="search__clear"
                        data-action="live#action"
                        data-live-action-param="clear"
                        aria-label="{{ 'search.clear'|trans({}, 'layout') }}">
                    <twig:ux:icon name="lucide:x" width="14" height="14" aria-hidden="true" />
                </button>
            {% endif %}
        </label>
        <button type="button"
                class="search__close"
                data-action="search#close"
                aria-label="{{ 'search.close'|trans({}, 'layout') }}">
            <span class="search__esc-key" aria-hidden="true">{{ 'search.esc_hint'|trans({}, 'layout') }}</span>
            <twig:ux:icon name="lucide:x" class="search__close-icon" width="20" height="20" aria-hidden="true" />
        </button>
    </header>

    <div class="search__body" data-loading="addClass(search__body--loading)">
        {% if this.empty %}
            <div class="search__empty">
                <section class="search__suggest">
                    <span class="kicker">{{ 'search.suggestions'|trans({}, 'messages') }}</span>
                    <ul class="search__suggest-chips">
                        {% for suggestion in this.suggestions %}
                            <li>
                                <button type="button"
                                        class="search__sug-chip"
                                        data-action="live#action"
                                        data-live-action-param="fillQuery"
                                        data-live-value-param="{{ suggestion }}">
                                    {{ suggestion }}
                                </button>
                            </li>
                        {% endfor %}
                    </ul>
                </section>
            </div>
        {% else %}
            {% set results = computed.results %}
            {% if results|length > 0 %}
                <section class="search__results"
                         aria-live="polite"
                         aria-label="{{ 'search.results_aria'|trans({ '%count%': results|length }, 'messages') }}">
                    <ul class="search__grid">
                        {% for result in results %}
                            {% set isHero = loop.first %}
                            <li>
                                <a href="{{ path('app_recipe_show', { recipeSlug: result.slug, categorySlug: result.categorySlug }) }}"
                                   class="search__card{% if isHero %} search__card--hero{% endif %}"
                                   data-action="search#close">
                                    <div class="search__card-media">
                                        <twig:Cover
                                            :media="result.media"
                                            variation="thumbnail"
                                            alt=""
                                            class="search__card-image"
                                        />
                                    </div>
                                    <div class="search__card-body">
                                        <h3 class="search__card-title">{{ result.title }}</h3>
                                        {% if result.headline %}
                                            <p class="search__card-desc">{{ result.headline|raw }}</p>
                                        {% endif %}
                                        <div class="search__card-foot">
                                            <span class="search__card-meta">{{ result.categoryTitle }}</span>
                                            <span class="search__card-arrow" aria-hidden="true">→</span>
                                        </div>
                                    </div>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </section>
            {% else %}
                <section class="search__no-results" aria-live="polite">
                    <div class="search__no-results-mark" aria-hidden="true">∅</div>
                    <h3 class="search__no-results-title">
                        {{ 'search.no_results_title_before'|trans({}, 'messages') }}
                        <em>{{ query }}</em>
                    </h3>
                    <p class="search__no-results-hint">{{ 'search.no_results_hint'|trans({}, 'messages') }}</p>
                    <twig:Button variant="soft" href="{{ path('app_recipe_index') }}">
                        {{ 'search.no_results_cta'|trans({}, 'messages') }}
                    </twig:Button>
                </section>
            {% endif %}
        {% endif %}
    </div>
</div>
