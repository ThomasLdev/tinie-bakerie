{% extends 'base.html.twig' %}

{% block body %}
    {% if featuredPost %}
        <section class="hero-wrap wrap">
            <twig:Hero :post="featuredPost" />
        </section>
    {% endif %}

    {% if featuredCategories|length > 0 %}
        <section class="section">
            <div class="wrap">
                <header class="section-head">
                    <div>
                        <span class="kicker">{{ 'home.categories.kicker'|trans }}</span>
                        <h2>{{ 'home.categories.title_before'|trans }} <em>{{ 'home.categories.title_em'|trans }}</em></h2>
                    </div>
                    <p class="sub">{{ 'home.categories.sub'|trans }}</p>
                </header>
            </div>
            <div class="wrap">
                <ul class="categories">
                    {% for category in featuredCategories %}
                        <li>
                            <twig:CategoryCard :category="category" />
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </section>
    {% endif %}

    {% if featuredPosts|length > 0 %}
        <section class="section">
            <div class="wrap">
                <header class="section-head">
                    <div>
                        <span class="kicker">{{ 'home.popular.kicker'|trans }}</span>
                        <h2>{{ 'home.popular.title_before'|trans }} <em>{{ 'home.popular.title_em'|trans }}</em></h2>
                    </div>
                    <a href="#" class="view-all">{{ 'home.popular.view_all'|trans }} →</a>
                </header>
            </div>
            <div class="wrap">
                <div class="popular">
                    {% for post in featuredPosts %}
                        <twig:RecipeCard
                            :post="post"
                            :featured="loop.first"
                            :badge="loop.first ? 'home.popular.badge_signature'|trans : null"
                        />
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
