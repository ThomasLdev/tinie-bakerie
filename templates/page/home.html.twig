{% extends 'base.html.twig' %}

{% block body %}
    {% if featuredPost %}
        <section class="hero-wrap wrap">
            <twig:Hero :post="featuredPost" />
        </section>
    {% endif %}

    {% if featuredTags|length > 0 %}
        <section class="section">
            <div class="wrap">
                <header class="section-head">
                    <div>
                        <span class="kicker">{{ 'home.tags.kicker'|trans }}</span>
                        <h2>{{ 'home.tags.title_before'|trans }} <em>{{ 'home.tags.title_em'|trans }}</em></h2>
                    </div>
                    <p class="sub">{{ 'home.tags.sub'|trans }}</p>
                </header>
            </div>
            <div class="wrap">
                <ul class="tags">
                    {% for tag in featuredTags %}
                        <li>
                            <twig:TagCard :tag="tag" />
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </section>
    {% endif %}

    {% if featuredPosts|length > 0 %}
        <section class="section">
            <div class="wrap">
                <header class="section-head">
                    <div>
                        <span class="kicker">{{ 'home.popular.kicker'|trans }}</span>
                        <h2>{{ 'home.popular.title_before'|trans }} <em>{{ 'home.popular.title_em'|trans }}</em></h2>
                    </div>
                    <a href="#" class="view-all">{{ 'home.popular.view_all'|trans }} →</a>
                </header>
            </div>
            <div class="wrap">
                <div class="popular">
                    {% for post in featuredPosts %}
                        <twig:RecipeCard
                            :post="post"
                            :featured="loop.first"
                            :badge="loop.first ? 'home.popular.badge_signature'|trans : null"
                        />
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    <section class="section">
        <div class="wrap">
            <twig:QuoteStrip
                :kicker="'home.philosophy.kicker'|trans"
                :quote="'home.philosophy.quote'|trans"
                :author="'home.philosophy.author'|trans"
            />
        </div>
    </section>
{% endblock %}
