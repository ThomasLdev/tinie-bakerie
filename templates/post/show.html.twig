{% extends 'base.html.twig' %}

{% block title %}{{ post.metaTitle }}{% endblock %}

{% block extra_header %}
    <meta name="description" content="{{ post.metaDescription }}">
    <meta property="og:title" content="{{ post.metaTitle }}" />
    <meta property="og:type" content="article" />
    <meta property="og:url" content="{{ path('app_post_show', {'postSlug': post.slug, 'categorySlug': post.category.slug}) }}" />
    <meta property="og:image" content="{{ post.media|first.media.path }}" />
    <meta property="og:site_name" content="Tinie Bakerie" />
{% endblock %}

{% block body %}
    {% if post is defined and post is not same as null %}
        <main class="min-h-screen">
            <div class="max-w-7xl mx-auto xl:px-0 px-6 py-12">
                {% include('post/includes/_header.html.twig') %}

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
                    {% include('post/includes/_sidebar-left.html.twig') %}

                    {% if post.sections is not empty %}
                        {% include('post/includes/_section.html.twig') %}
                    {% endif %}
                </div>
            </div>
        </main>
    {% endif %}
{% endblock %}
